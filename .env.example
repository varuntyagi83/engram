# ============================================================
# Memory Engine — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Required for ALL modes (local + cloud) ─────────────────
OPENAI_API_KEY=sk-...
# Used for:
#   - Memory extraction fallback (gpt-4o-mini, ~$0.0003/call)
#   - Pro: semantic search embeddings (text-embedding-3-small)
#   - Pro: memory summarization (gpt-4o-mini)
# Default extraction uses MEMORIES_JSON parsing = $0 cost

# ── Storage mode ───────────────────────────────────────────
MEMORY_ENGINE_MODE=local
# Options: local (SQLite, default) | cloud (Supabase, Pro)

# ── Local mode config (optional overrides) ─────────────────
MEMORY_ENGINE_DB_PATH=~/.memory-engine/db.sqlite
MEMORY_ENGINE_USER_ID=default

# ── Cloud / Pro mode (only needed if MODE=cloud) ───────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Dashboard (optional) ───────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000
